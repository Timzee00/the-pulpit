# ============================================================
#  The Pulpit — Sermon Helper AI
#  Environment Variables
# ============================================================
#
#  INSTRUCTIONS:
#  1. Copy this file and rename it to: .env
#  2. Fill in your real API key below
#  3. NEVER commit .env to Git — it is already in .gitignore
#
#  For Netlify production deployment:
#  → Go to: Netlify Dashboard → Your Site → Site Settings → Environment Variables
#  → Add: OPENROUTER_API_KEY = your real key
#  → Redeploy the site
#
#  Get your OpenRouter key at: https://openrouter.ai/keys
# ============================================================

OPENROUTER_API_KEY=sk-or-v1-your-key-here
